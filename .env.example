# 向量模型配置
# 用于 FAISS 法规知识库构建与查询，需使用 OpenAI 兼容 Embedding API
BASE_URL=https://your-embedding-provider.example/v1
API_KEY=your_embedding_api_key
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# 聊天大模型配置（推荐使用通用变量名）
# 用于 Auditor / Critic 双智能体审查和法律咨询助手
LLM_BASE_URL=https://your-llm-provider.example/v1
LLM_API_KEY=your_llm_api_key
CHAT_MODEL_NAME=your_chat_model_name

# 兼容旧配置名：如果未设置 LLM_* / CHAT_MODEL_NAME，系统会回退读取以下变量
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL_NAME=deepseek-chat

# 页面展示配置
APP_NAME=基于多智能体的个人劳动合同风险预警系统
APP_SUBTITLE=极简、安全、专业的双智能体协同劳动合同风险预警系统


# 文档解析配置：legacy / mineru_cli
# legacy：使用项目内置轻量解析器
# mineru_cli：上传合同优先使用本地 MinerU CLI 增强解析，失败时自动回退 legacy
DOCUMENT_PARSER=mineru_cli

# MinerU 本地 CLI 增强解析配置
# MinerU 是可选增强依赖，推荐安装到独立虚拟环境，避免污染项目主 venv
# 推荐相对路径示例：MINERU_CLI_COMMAND=..\mineru-venv\Scripts\mineru.exe
# 可选 GPU 加速不需要额外环境变量；请在独立 MinerU 环境中确认 torch.cuda.is_available() 为 True
MINERU_CLI_COMMAND=..\mineru-venv\Scripts\mineru.exe
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_FORMULA=false
MINERU_TABLE=true
MINERU_TIMEOUT_SECONDS=600
MINERU_MODEL_SOURCE=modelscope